# Copy this file to `.env` for local use only.
# `.env` is gitignored and must not be pushed to GitHub.
#
# Cloudflare Pages (production): set variables in the dashboard
#   Workers & Pages → portfolio-site → Settings → Environment variables
#   e.g. NODE_VERSION=22

# --- Cloudflare Wrangler (optional: deploy from your machine) ---
# Token permissions: Account → Cloudflare Pages (Edit), Account Settings (Read)
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=

# --- Optional: password-protected routes (local dev only) ---
# Static export on Cloudflare Pages does not use src/app/api routes.
# PAGE_ACCESS_PASSWORD=
